:TemperatureSensor1Procedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :TemperatureSensor1MeasuredRoomTemperature .

<http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1>
        rdf:type     owl:Ontology;
        owl:imports  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins> .

:FloorHeating  rdf:type       <http://www.w3.org/ns/sosa/Actuator> , owl:NamedIndividual;
        rdt:enacts            :RoomTemperatureIncrease , :EnergyConsumptionIncrease;
        rdt:hasActuatorState  "1"^^xsd:int , "0"^^xsd:int .

:MotionSensorMeasuredMotion
        rdf:type      <http://www.w3.org/ns/ssn/Property> , <http://www.w3.org/ns/ssn/Output> , owl:NamedIndividual;
        rdt:hasValue  "True"^^xsd:boolean .

:RoomHumidity  rdf:type  <http://www.w3.org/ns/sosa/ObservableProperty> , owl:NamedIndividual;
        rdt:hasValue  "48.293929202415896"^^xsd:double .

:RoomHumidityDecrease
        rdf:type                 rdt:PropertyChange , owl:NamedIndividual;
        rdt:affectsPropertyWith  rdt:ValueDecrease;
        <http://www.w3.org/ns/ssn/forProperty>
                :RoomHumidity .

:TemperatureSensor2Procedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :TemperatureSensor2MeasuredRoomTemperature .

:HumiditySensor  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :RoomHumidity;
        <http://www.w3.org/ns/ssn/implements>
                :HumiditySensorProcedure .

:OfficeTemperatureUpperLimit
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "22.0"^^xsd:double .

:MotionActivated  rdf:type  <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  true .

:RoomM370FMU  rdf:type  rdt:FmuModel , owl:NamedIndividual;
        rdt:hasSimulationFidelitySeconds
                "100"^^xsd:int;
        rdt:hasURI  "roomM370.fmu"^^xsd:anyURI .

:RoomTemperatureLowerLimit1
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "27.5"^^xsd:double .

:RoomTemperatureUpperLimit1
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "30.2"^^xsd:double .

:MotionSensor  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :Motion;
        <http://www.w3.org/ns/ssn/implements>
                :MotionSensorProcedure .

:RoomM370  rdf:type             <http://www.w3.org/ns/sosa/Platform> , owl:NamedIndividual;
        rdt:generateCombinationsOnlyFromOptimalConditions
                false;
        rdt:hasSimulationModel  :RoomM370FMU;
        rdt:minimizes           :EnergyConsumption;
        <http://www.w3.org/ns/sosa/hosts>
                :EnergyConsumptionMeter , :TemperatureSensor1 , :HumiditySensor , :Dehumidifier , :TemperatureSensor2 , :FloorHeating , :Heater .

:Dehumidifier  rdf:type       <http://www.w3.org/ns/sosa/Actuator> , owl:NamedIndividual;
        rdt:enacts            :RoomHumidityDecrease , :EnergyConsumptionIncrease;
        rdt:hasActuatorState  "1"^^xsd:int , "0"^^xsd:int .

:HumiditySensorProcedure
        rdf:type  <http://www.w3.org/ns/sosa/Procedure> , owl:NamedIndividual;
        <http://www.w3.org/ns/ssn/hasOutput>
                :HumiditySensorMeasuredRoomHumidity .

:OfficeHumidityUpperLimit
        rdf:type      <http://www.w3.org/ns/ssn/Property> , owl:NamedIndividual;
        rdt:hasValue  "50.0"^^xsd:double .

:EnergyConsumptionMeterMeasuredEnergyConsumption
        rdf:type      <http://www.w3.org/ns/ssn/Property> , <http://www.w3.org/ns/ssn/Output> , owl:NamedIndividual;
        rdt:hasValue  "28.043967099999996"^^xsd:double .

:TemperatureSensor2  rdf:type  <http://www.w3.org/ns/sosa/Sensor> , owl:NamedIndividual;
        <http://www.w3.org/ns/sosa/observes>
                :RoomTemperature;
        <http://www.w3.org/ns/ssn/implements>
                :TemperatureSensor2Procedure .

:TemperatureSensor2MeasuredRoomTemperature
        rdf:type      <http://www.w3.org/ns/ssn/Property> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Input> , owl:NamedIndividual;
        rdt:hasValue  "18.73023447172133"^^xsd:double .

:TemperatureSensor1MeasuredRoomTemperature
        rdf:type      <http://www.w3.org/ns/ssn/Property> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Input> , owl:NamedIndividual;
        rdt:hasValue  "18.73023447172133"^^xsd:double .

:EnergyConsumptionIncrease
        rdf:type                 rdt:PropertyChange , owl:NamedIndividual;
        rdt:affectsPropertyWith  rdt:ValueIncrease;
        <http://www.w3.org/ns/ssn/forProperty>
                :EnergyConsumption .
