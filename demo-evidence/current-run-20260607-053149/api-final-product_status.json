{
  "appMode": "full",
  "persistence": {
    "goals": {
      "provider": "json",
      "path": "config/user-goals.example.json"
    },
    "decisions": {
      "provider": "memory",
      "path": null
    },
    "settings": {
      "provider": "memory",
      "path": null
    },
    "executionHistory": {
      "provider": "sqlite",
      "path": "data/execution-history.sqlite"
    },
    "safetyEvents": {
      "provider": "memory",
      "path": null
    }
  },
  "homeAssistant": {
    "configured": true,
    "urlSet": true,
    "tokenSet": true,
    "connected": true,
    "source": "runtime"
  },
  "autonomous": {
    "requested": false,
    "realExecutionRequested": false,
    "dryRunOnly": true
  },
  "safety": {
    "allowExecution": false,
    "killSwitchEngaged": false,
    "tokenPresent": true,
    "allowedEntityCount": 0,
    "allowedServiceCount": 0,
    "actionCooldownSeconds": 0,
    "maxActionsPerHour": 0,
    "maxActionsPerEntityPerHour": 0,
    "eventLogProvider": "memory"
  },
  "build": {
    "version": "1.0.0.0",
    "informationalVersion": "1.0.0+94e4d0f8593d09e2646e9e61df036db1793d98d8"
  }
}
