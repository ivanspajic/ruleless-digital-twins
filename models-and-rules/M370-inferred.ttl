:OfficeTemperatureOptimalCondition
        rdf:type    owl:NamedIndividual , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition>;
        rdf:type    [ rdf:type                  owl:Restriction;
                      owl:onClass               [ rdf:type            owl:Class;
                                                  owl:intersectionOf  ( [ rdf:type                       owl:Restriction;
                                                                          :withCheck                     "conjunction";
                                                                          :withConstraintType            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint>;
                                                                          :withIdentifier                _:b7;
                                                                          :withOperatorCheck             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/greaterThan>;
                                                                          :withOptimalCondition          :OfficeTemperatureOptimalCondition;
                                                                          :withOptimalConditionProperty  :RoomTemperature;
                                                                          :withPropertyChangeCheck       <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease>;
                                                                          :withPropertyCheck             :OfficeTemperatureLowerLimit , :RoomTemperature;
                                                                          owl:hasValue                   :OfficeTemperatureLowerLimit;
                                                                          owl:onProperty                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/greaterThan>
                                                                        ]
                                                                        [ rdf:type                       owl:Restriction;
                                                                          :withCheck                     "conjunction";
                                                                          :withConstraintType            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint>;
                                                                          :withIdentifier                _:b7;
                                                                          :withOperatorCheck             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/lessThanOrEqualTo>;
                                                                          :withOptimalCondition          :OfficeTemperatureOptimalCondition;
                                                                          :withOptimalConditionProperty  :RoomTemperature;
                                                                          :withPropertyChangeCheck       <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease>;
                                                                          :withPropertyCheck             :OfficeTemperatureUpperLimit;
                                                                          owl:hasValue                   :OfficeTemperatureUpperLimit;
                                                                          owl:onProperty                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/lessThanOrEqualTo>
                                                                        ]
                                                                      )
                                                ];
                      owl:onProperty            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint>;
                      owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger
                    ];
        rdf:type    [ rdf:type                  owl:Restriction;
                      owl:onClass               [ rdf:type                       owl:Restriction;
                                                  :withConstraintType            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasEnablingConstraint>;
                                                  :withOperatorCheck             <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/equalTo>;
                                                  :withOptimalCondition          :OfficeTemperatureOptimalCondition;
                                                  :withOptimalConditionProperty  :RoomTemperature;
                                                  :withPropertyChangeCheck       <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease> , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease>;
                                                  :withPropertyCheck             :MotionActivated , :RoomTemperature;
                                                  owl:hasValue                   :MotionActivated;
                                                  owl:onProperty                 <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/equalTo>
                                                ];
                      owl:onProperty            <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasEnablingConstraint>;
                      owl:qualifiedCardinality  "1"^^xsd:nonNegativeInteger
                    ];
        :isEnabled  true;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/forEnablingProperty>
                :Motion;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isBreakable>
                true;
        <http://www.w3.org/ns/ssn/forProperty>
                :RoomTemperature .

