###  http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#OfficeHumidityLowerLimit
:OfficeHumidityLowerLimit rdf:type owl:NamedIndividual ,
                                   <http://www.w3.org/ns/ssn/Property> ;
                          rdt:hasValue "30.0"^^xsd:double .


###  http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#OfficeHumidityOptimalCondition
:OfficeHumidityOptimalCondition rdf:type owl:NamedIndividual ,
                                         rdt:OptimalCondition ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty rdt:hasConstraint ;
                                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                           owl:onClass [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                owl:onProperty rdt:greaterThanOrEqualTo ;
                                                                                owl:hasValue :OfficeHumidityLowerLimit
                                                                              ]
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty rdt:lessThanOrEqualTo ;
                                                                                owl:hasValue :OfficeHumidityUpperLimit
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                         ] ;
                                <http://www.w3.org/ns/ssn/forProperty> :RoomHumidity ;
                                rdt:isBreakable "true"^^xsd:boolean ;
                                rdt:satisfiedBy "0001-01-01T09:00:00Z"^^xsd:dateTimeStamp .


###  http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1#OfficeHumidityUpperLimit
