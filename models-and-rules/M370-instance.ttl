:OfficeHumidityLowerLimit <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "30.0"^^xsd:double;
                          a owl:NamedIndividual,
                            <http://www.w3.org/ns/ssn/Property>.
:OfficeHumidityOptimalCondition <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isBreakable> true;
                                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/satisfiedBy> "0001-01-01T09:00:00Z"^^xsd:dateTimeStamp;
                                a owl:NamedIndividual,
                                  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition>,
                                  [a owl:Restriction ; 
                                   owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasConstraint> ; 
                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                   owl:onClass [owl:intersectionOf ([a owl:Restriction ; 
                                                                    owl:onProperty rdt:greaterThanOrEqualTo ; 
                                                                    owl:hasValue :OfficeHumidityLowerLimit]
                                                                    [a owl:Restriction ; 
                                                                    owl:onProperty rdt:lessThanOrEqualTo ; 
                                                                    owl:hasValue :OfficeHumidityUpperLimit]) ; 
                                                a owl:Class]];
                                <http://www.w3.org/ns/ssn/forProperty> :RoomHumidity.
:OfficeHumidityUpperLimit <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "50.0"^^xsd:double;
                          a owl:NamedIndividual,
                            <http://www.w3.org/ns/ssn/Property>.
:OfficeTemperatureLowerLimit <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "18.0"^^xsd:double;
                             a owl:NamedIndividual,
                               <http://www.w3.org/ns/ssn/Property>.
:OfficeTemperatureOptimalCondition <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/forEnablingProperty> :Motion;
                                   <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/isBreakable> true;
                                   a owl:NamedIndividual,
                                     <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/OptimalCondition>,
                                     [a owl:Restriction ; 
                                      owl:onProperty rdt:hasConstraint ; 
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                      owl:onClass [owl:intersectionOf ([a owl:Restriction ; 
                                                                       owl:onProperty rdt:greaterThan ; 
                                                                       owl:hasValue :OfficeTemperatureLowerLimit]
                                                                       [a owl:Restriction ; 
                                                                       owl:onProperty rdt:lessThanOrEqualTo ; 
                                                                       owl:hasValue :OfficeTemperatureUpperLimit]) ; 
                                                   a owl:Class]],
                                     [a owl:Restriction ; 
                                      owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasEnablingConstraint> ; 
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ; 
                                      owl:onClass [a owl:Restriction ; 
                                                   owl:onProperty <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/equalTo> ; 
                                                   owl:hasValue :MotionActivated]];
                                   <http://www.w3.org/ns/ssn/forProperty> :RoomTemperature.
:OfficeTemperatureUpperLimit <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue> "22.0"^^xsd:double;
                             a owl:NamedIndividual,
                               <http://www.w3.org/ns/ssn/Property>.
