  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActions>
          _:b31;
  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuators>
          _:b55
] .

:HumiditySensorMeasuredHumidity
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "8.065931477520403"^^xsd:double .

:RoomTemperatureIncrease
        rdf:type  owl:NamedIndividual , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith>
                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueIncrease>;
        <http://www.w3.org/ns/ssn/forProperty>
                :RoomTemperature .

:IncreaseTemperatureSoftSensorProcedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasInput>
                :TemperatureSensor1MeasuredTemperature , :TemperatureSensor2MeasuredTemperature;
        <http://www.w3.org/ns/ssn/hasOutput>
                :IncreasedTemperature .

:OfficeTemperatureLowerLimit
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "18.0"^^xsd:double .

:RoomTemperature  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/ObservableProperty>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "10.0"^^xsd:double .

:EnergyConsumptionMeterProcedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasOutput>
                :EnergyConsumptionMeterMeasuredEnergyConsumption .

:TemperatureSensor1MeasuredTemperature
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Input> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "16.746512725848774"^^xsd:double .

:EnergyConsumption  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/ObservableProperty>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "0.0"^^xsd:double .

:FakepoolFMU  rdf:type  owl:NamedIndividual , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/FmuModel>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationFidelitySeconds>
                "900"^^xsd:int;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasURI>
                "Fakepool.fmu"^^xsd:anyURI .

:MotionSensorProcedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasOutput>
                :MotionSensorMeasuredMotion .

:PriceSensor  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/sosa/observes>
                :Price;
        <http://www.w3.org/ns/ssn/implements>
                :PriceProcedure .

:RoomTemperatureLowerLimit2
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "10.0"^^xsd:double .

:EnergyConsumptionDecrease
        rdf:type  owl:NamedIndividual , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith>
                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease>;
        <http://www.w3.org/ns/ssn/forProperty>
                :EnergyConsumption .

:Heater  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Actuator>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts>
                :EnergyConsumptionIncrease , :RoomTemperatureIncrease;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState>
                "0"^^xsd:int , "1"^^xsd:int , "2"^^xsd:int .

:RoomTemperatureUpperLimit2
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "10.0"^^xsd:double .

:OfficeHumidityLowerLimit
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "30.0"^^xsd:double .

:TemperatureSensor1  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/sosa/observes>
                :RoomTemperature;
        <http://www.w3.org/ns/ssn/implements>
                :TemperatureSensor1Procedure .

:TemperatureSensor2MeasuredTemperature
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Input> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "16.746512725848774"^^xsd:double .

:Motion  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/ObservableProperty>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                false .

:EnergyConsumptionMeter
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/sosa/observes>
                :EnergyConsumption;
        <http://www.w3.org/ns/ssn/implements>
                :EnergyConsumptionMeterProcedure .

:TemperatureSensor1Procedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasOutput>
                :TemperatureSensor1MeasuredTemperature .

<http://www.semanticweb.org/ivans/ontologies/2025/instance-model-1>
        rdf:type     owl:Ontology;
        owl:imports  <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins> .

:AverageTemperatureSoftSensor
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/ssn/implements>
                :AverageTemperatureSoftSensorProcedure .

:FloorHeating  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Actuator>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts>
                :EnergyConsumptionIncrease , :RoomTemperatureIncrease;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState>
                "0"^^xsd:int , "1"^^xsd:int .

:MotionSensorMeasuredMotion
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                false .

:RoomHumidity  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/ObservableProperty>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "8.065931477520403"^^xsd:double .

:IncreasedTemperature
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Input> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "19.246512725848774"^^xsd:double .

:PriceProcedure  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasOutput>
                :PriceMeasure;
        <http://www.w3.org/ns/ssn/implementedBy>
                :PriceSensor .

:RoomHumidityDecrease
        rdf:type  owl:NamedIndividual , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/PropertyChange>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/affectsPropertyWith>
                <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/ValueDecrease>;
        <http://www.w3.org/ns/ssn/forProperty>
                :RoomHumidity .

:DecreaseTemperatureSoftSensor
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/ssn/implements>
                :DecreaseTemperatureSoftSensorProcedure .

:PriceMeasure  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "0.0"^^xsd:double .

:TemperatureSensor2Procedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasOutput>
                :TemperatureSensor2MeasuredTemperature .

:HumiditySensor  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/sosa/observes>
                :RoomHumidity;
        <http://www.w3.org/ns/ssn/implements>
                :HumiditySensorProcedure .

:OfficeTemperatureUpperLimit
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "22.0"^^xsd:double .

:MotionActivated  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                true .

:RoomM370FMU  rdf:type  owl:NamedIndividual , <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/FmuModel>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationFidelitySeconds>
                "100"^^xsd:int;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasURI>
                "roomM370.fmu"^^xsd:anyURI .

:DecreasedTemperature
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Input> , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "14.246512725848774"^^xsd:double .

:RoomTemperatureLowerLimit1
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "27.5"^^xsd:double .

:DecreaseTemperatureSoftSensorProcedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasInput>
                :TemperatureSensor1MeasuredTemperature , :TemperatureSensor2MeasuredTemperature;
        <http://www.w3.org/ns/ssn/hasOutput>
                :DecreasedTemperature .

:RoomTemperatureUpperLimit1
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Property>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasValue>
                "30.2"^^xsd:double .

:MotionSensor  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Sensor>;
        <http://www.w3.org/ns/sosa/observes>
                :Motion;
        <http://www.w3.org/ns/ssn/implements>
                :MotionSensorProcedure .

:AverageTemperatureSoftSensorProcedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasInput>
                :DecreasedTemperature , :IncreasedTemperature;
        <http://www.w3.org/ns/ssn/hasOutput>
                :AverageTemperature .

:Dehumidifier  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Actuator>;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/enacts>
                :EnergyConsumptionIncrease , :RoomHumidityDecrease;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasActuatorState>
                "0"^^xsd:int , "1"^^xsd:int .

:RoomM370  rdf:type  <http://www.w3.org/ns/sosa/Platform> , owl:NamedIndividual;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/generateCombinationsOnlyFromOptimalConditions>
                false;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/hasSimulationModel>
                :RoomM370FMU;
        <http://www.semanticweb.org/ivans/ontologies/2025/ruleless-digital-twins/minimizes>
                :EnergyConsumption , :Price;
        <http://www.w3.org/ns/sosa/hosts>
                :PriceSensor , :EnergyConsumptionMeter , :TemperatureSensor1 , :HumiditySensor , :Dehumidifier , :TemperatureSensor2 , :Heater , :FloorHeating .

:HumiditySensorProcedure
        rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/sosa/Procedure>;
        <http://www.w3.org/ns/ssn/hasOutput>
                :HumiditySensorMeasuredHumidity .

:AverageTemperature  rdf:type  owl:NamedIndividual , <http://www.w3.org/ns/ssn/Output> , <http://www.w3.org/ns/ssn/Property>;
